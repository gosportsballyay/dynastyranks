# Database - Get from Neon Console (https://console.neon.tech)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# NextAuth - Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Optional: Set to your domain in production
# AUTH_URL="https://your-domain.com"

# Beta access gate — set a code to restrict access, remove to open site
BETA_ACCESS_CODE="your-beta-code-here"

# Yahoo Fantasy — set to "true" once OAuth credentials are configured
NEXT_PUBLIC_YAHOO_ENABLED="false"

# App URL — used for meta tags, sitemap, etc.
# NEXT_PUBLIC_APP_URL="https://dynastyranks.com"
